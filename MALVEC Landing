<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MALVEC — Digital Agency</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Degular+Display:wght@400;500;600;700&family=Degular:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #efeee6;
    --pink: #9f004a;
    --dark: #160026;
    --accent: #92004a;
    --grad: linear-gradient(135deg, #160026 0%, #92004a 100%);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--dark);
    color: var(--cream);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  /* CURSOR */
  .cursor {
    width: 12px; height: 12px;
    background: var(--pink);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transition: transform 0.1s ease;
    mix-blend-mode: difference;
  }
  .cursor-ring { display: none; }
  .cursor-ring.hovered { display: none; }

  /* NOISE */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 1000; opacity: 0.4;
  }

  /* PROGRESS BAR */
  .progress-bar {
    position: fixed; top: 0; left: 0;
    height: 2px;
    background: var(--grad);
    z-index: 9000;
    width: 0%;
    transition: width 0.05s linear;
  }

  /* CURSOR GLOW + TRAIL */
  .cursor {
    box-shadow: 0 0 10px 3px rgba(159,0,74,0.6) !important;
    mix-blend-mode: normal !important;
  }
  .cursor-trail {
    position: fixed; pointer-events: none; z-index: 9997;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(159,0,74,0.85) 0%, rgba(159,0,74,0) 70%);
    transform: translate(-50%, -50%);
    animation: trailFade 0.5s ease-out forwards;
  }
  @keyframes trailFade {
    0%   { opacity: 0.7; width: 8px;  height: 8px; }
    100% { opacity: 0;   width: 22px; height: 22px; }
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 500;
    padding: 24px 48px;
    display: flex; justify-content: space-between; align-items: center;
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    background: rgba(22, 0, 38, 0.4);
    border-bottom: 1px solid rgba(239, 238, 230, 0.06);
    transition: padding 0.4s ease;
  }
  nav.scrolled { padding: 16px 48px; }

  .nav-logo {
    font-size: 22px; font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--cream);
  }
  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a {
    color: rgba(239,238,230,0.6);
    text-decoration: none; font-size: 13px;
    letter-spacing: 0.1em; text-transform: uppercase;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--cream); }
  .nav-cta {
    padding: 10px 24px;
    background: var(--grad);
    color: var(--cream) !important;
    border-radius: 100px;
    font-weight: 500 !important;
    letter-spacing: 0.05em !important;
    text-transform: none !important;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    justify-content: center; align-items: flex-start;
    padding: 140px 48px 80px;
    position: relative; overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 80% 50%, rgba(146,0,74,0.18) 0%, transparent 60%),
                radial-gradient(ellipse 50% 50% at 20% 80%, rgba(22,0,38,0.8) 0%, transparent 70%);
  }
  .orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px);
    animation: float 8s ease-in-out infinite;
  }
  .orb-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(159,0,74,0.25), transparent 70%);
    top: -100px; right: -100px; animation-delay: 0s;
  }
  .orb-2 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(146,0,74,0.15), transparent 70%);
    bottom: 0; right: 30%; animation-delay: -3s;
  }
  .orb-3 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(239,238,230,0.04), transparent 70%);
    top: 40%; left: 60%; animation-delay: -5s;
  }
  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.97); }
  }

  .hero-tag {
    font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--pink); margin-bottom: 24px;
    display: flex; align-items: center; gap: 12px;
    opacity: 0; animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero-tag::before { content: ''; width: 32px; height: 1px; background: var(--pink); }

  .hero-title {
    font-size: clamp(56px, 9vw, 120px);
    line-height: 1.15;
    font-weight: 700;
    font-family: 'Degular Display', sans-serif;
    color: var(--cream);
    margin-bottom: 32px;
    opacity: 0; animation: fadeUp 0.8s 0.4s forwards;
  }
  .hero-title .line-grad {
    color: #9f004a;
    -webkit-text-fill-color: #9f004a;
    display: block;
    line-height: 1.15;
    margin: 0;
    padding: 0;
  }

  .hero-sub {
    max-width: 480px; font-size: 17px; line-height: 1.7;
    color: rgba(239,238,230,0.72); margin-bottom: 48px;
    opacity: 0; animation: fadeUp 0.8s 0.6s forwards;
  }
  .hero-actions {
    display: flex; gap: 16px; align-items: center;
    opacity: 0; animation: fadeUp 0.8s 0.8s forwards;
  }

  .btn-primary {
    padding: 16px 36px; background: var(--grad);
    color: var(--cream); border: none; border-radius: 100px;
    font-size: 14px; font-weight: 500; letter-spacing: 0.05em;
    cursor: none; text-decoration: none;
    transition: transform 0.2s, box-shadow 0.3s;
    box-shadow: 0 0 40px rgba(159,0,74,0.3);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 60px rgba(159,0,74,0.5); }

  .btn-ghost {
    padding: 16px 36px; background: transparent;
    color: rgba(239,238,230,0.7);
    border: 1px solid rgba(239,238,230,0.15); border-radius: 100px;
    font-size: 14px; letter-spacing: 0.05em;
    cursor: none; text-decoration: none;
    transition: border-color 0.3s, color 0.3s;
  }
  .btn-ghost:hover { border-color: rgba(239,238,230,0.4); color: var(--cream); }

  .hero-scroll {
    position: absolute; bottom: 40px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0; animation: fadeIn 1s 1.2s forwards;
  }
  .hero-scroll span { font-size: 10px; letter-spacing: 0.2em; color: rgba(239,238,230,0.3); text-transform: uppercase; }
  .scroll-line {
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, rgba(159,0,74,0.7), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100%{opacity:0.3;transform:scaleY(1)} 50%{opacity:1;transform:scaleY(1.2)} }
  @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }

  /* MARQUEE */
  .marquee-section {
    padding: 20px 0;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    overflow: hidden;
    background: #000;
  }
  .marquee-track {
    display: flex; gap: 0;
    animation: marquee 20s linear infinite;
    white-space: nowrap;
  }
  .marquee-item {
    display: inline-flex; align-items: center;
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--dark);
  }
  .marquee-item span:first-child { padding: 0 28px; }
  .marquee-item .dot {
    width: 5px; height: 5px;
    background: var(--pink); border-radius: 50%;
    flex-shrink: 0; display: inline-block;
  }
  @keyframes marquee { from { transform:translateX(0); } to { transform:translateX(-50%); } }

  /* SECTION */
  section { padding: 120px 48px; }

  .section-label {
    font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--pink); margin-bottom: 20px;
    display: flex; align-items: center; gap: 12px;
  }
  .section-label::before { content: ''; width: 24px; height: 1px; background: var(--pink); }

  .section-title {
    font-family: 'Degular Display', sans-serif;
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 600; line-height: 1.05; margin-bottom: 16px;
  }

  /* SERVICES */
  .services { position: relative; background: var(--cream); }
  .services-header { max-width: 600px; margin-bottom: 80px; }
  .services-header p { font-size: 17px; color: rgba(22,0,38,0.65); line-height: 1.7; margin-top: 16px; }
  .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }

  .service-card {
    padding: 56px 48px;
    border: 1px solid rgba(22,0,38,0.1);
    background: rgba(22,0,38,0.03);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    position: relative; overflow: hidden;
    transition: background 0.4s, border-color 0.4s; cursor: none;
  }
  .service-card::before {
    content: ''; position: absolute; inset: 0;
    background: var(--grad); opacity: 0; transition: opacity 0.4s;
  }
  .service-card:hover { border-color: rgba(159,0,74,0.3); }
  .service-card:hover::before { opacity: 0.04; }

  .glass-highlight {
    position: absolute; width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
    border-radius: 50%; pointer-events: none;
    transform: translate(-50%, -50%); opacity: 0; transition: opacity 0.3s;
  }
  .service-card:hover .glass-highlight { opacity: 1; }

  .service-num { font-size: 11px; letter-spacing: 0.2em; color: rgba(22,0,38,0.35); margin-bottom: 32px; display: block; }
  .service-icon {
    width: 48px; height: 48px; margin-bottom: 28px;
    background: var(--grad); border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
  }
  .service-icon svg { width: 22px; height: 22px; stroke: var(--cream); fill: none; stroke-width: 1.5; }
  .service-name {
    font-family: 'Degular Display', sans-serif;
    font-size: 28px; font-weight: 600; margin-bottom: 16px; line-height: 1.15;
    position: relative; z-index: 1; color: var(--dark);
  }
  .service-desc {
    font-size: 15px; color: rgba(22,0,38,0.65); line-height: 1.7;
    position: relative; z-index: 1; margin-bottom: 32px;
  }
  .service-tags { display: flex; flex-wrap: wrap; gap: 8px; position: relative; z-index: 1; }
  .service-tag {
    padding: 5px 14px;
    border: 1px solid rgba(22,0,38,0.18); border-radius: 100px;
    font-size: 11px; letter-spacing: 0.1em; color: rgba(22,0,38,0.5); text-transform: uppercase;
  }
  .services .section-title { color: var(--dark); }

  /* ABOUT */
  #about { background: #000; }
  .philosophy { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .philosophy-visual { position: relative; height: 500px; }
  .phil-box {
    position: absolute;
    border: 1px solid rgba(239,238,230,0.08);
    background: rgba(239,238,230,0.02);
    backdrop-filter: blur(20px); border-radius: 16px; padding: 32px;
  }
  .phil-box-1 { width: 300px; top: 0; left: 0; }
  .phil-box-2 { width: 260px; bottom: 40px; right: 0; }
  .phil-box-3 {
    width: 180px; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: var(--grad); border-color: transparent; text-align: center;
  }
  .phil-metric { font-size: 48px; font-family: 'Degular Display', sans-serif; font-weight: 700; color: var(--cream); }
  .phil-metric-label { font-size: 13px; color: rgba(239,238,230,0.55); margin-top: 4px; }
  .phil-box-3 .phil-metric { font-size: 36px; color: #fff; }
  .phil-box-3 .phil-metric-label { color: rgba(255,255,255,0.75) !important; }
  .philosophy-text .section-title { margin-bottom: 24px; }
  .philosophy-text p { font-size: 16px; line-height: 1.8; color: rgba(239,238,230,0.68); margin-bottom: 20px; }
  .accent-line { width: 60px; height: 2px; background: var(--grad); margin: 32px 0; }

  /* PROCESS */
  .process-section { background: rgba(239,238,230,0.015); }
  .process-steps {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px; margin-top: 80px; background: rgba(239,238,230,0.06);
  }
  .process-step {
    background: var(--dark); padding: 48px 36px;
    position: relative; overflow: hidden; transition: background 0.3s;
  }
  .process-step:hover { background: rgba(159,0,74,0.04); }
  .process-step-num {
    font-size: 72px; font-family: 'Degular Display', sans-serif; font-weight: 700;
    color: rgba(239,238,230,0.08); line-height: 1; margin-bottom: 24px; transition: color 0.3s;
  }
  .process-step:hover .process-step-num { color: rgba(159,0,74,0.35); }
  .process-step-title { font-family: 'Degular Display', sans-serif; font-size: 22px; font-weight: 600; margin-bottom: 12px; }
  .process-step-desc { font-size: 14px; color: rgba(239,238,230,0.6); line-height: 1.7; }

  /* CTA */
  .cta-section {
    position: relative; overflow: hidden;
    padding: 120px 48px; text-align: center;
    background: var(--cream);
  }
  .cta-blob {
    position: absolute; width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(146,0,74,0.2) 0%, transparent 60%);
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    border-radius: 50%; filter: blur(60px);
    animation: pulse 5s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,-50%) scale(1.1)} }
  .cta-inner { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; }
  .cta-inner .section-title { font-size: clamp(40px, 6vw, 72px); margin-bottom: 24px; color: var(--dark); }
  .cta-inner p { font-size: 18px; color: rgba(22,0,38,0.65); line-height: 1.7; margin-bottom: 48px; }
  .cta-card {
    display: inline-block; padding: 56px 80px;
    background: rgba(22,0,38,0.04);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid rgba(22,0,38,0.12); border-radius: 24px;
    box-shadow: 0 32px 80px rgba(22,0,38,0.08), inset 0 1px 0 rgba(255,255,255,0.6);
  }

  .cta-section .btn-ghost { border-color: rgba(22,0,38,0.5); color: var(--dark); }
  .cta-section .btn-ghost:hover { border-color: var(--dark); color: var(--dark); }

  /* FOOTER */
  footer { padding: 80px 48px 40px; border-top: 1px solid rgba(239,238,230,0.06); }
  .footer-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 60px; }
  .footer-logo { font-size: 32px; font-weight: 700; letter-spacing: 0.2em; color: var(--cream); margin-bottom: 16px; }
  .footer-tagline { font-size: 14px; color: rgba(239,238,230,0.5); max-width: 260px; line-height: 1.6; }
  .footer-links { display: flex; gap: 80px; }
  .footer-col h4 { font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(239,238,230,0.4); margin-bottom: 20px; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .footer-col a { color: rgba(239,238,230,0.65); text-decoration: none; font-size: 14px; transition: color 0.2s; }
  .footer-col a:hover { color: var(--cream); }
  .footer-bottom {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 32px; border-top: 1px solid rgba(239,238,230,0.06);
    font-size: 12px; color: rgba(239,238,230,0.4); letter-spacing: 0.05em;
  }
  .footer-bottom span { display: flex; align-items: center; gap: 6px; }
  .argentina-dot { width: 8px; height: 8px; background: var(--pink); border-radius: 50%; }

  /* SCROLL REVEAL */
  .reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-left { opacity: 0; transform: translateX(-40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal-left.visible { opacity: 1; transform: translateX(0); }
  .reveal-right { opacity: 0; transform: translateX(40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal-right.visible { opacity: 1; transform: translateX(0); }
  .stagger > * { opacity: 0; transform: translateY(30px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .stagger.visible > *:nth-child(1) { opacity:1; transform:none; transition-delay:0.0s; }
  .stagger.visible > *:nth-child(2) { opacity:1; transform:none; transition-delay:0.1s; }
  .stagger.visible > *:nth-child(3) { opacity:1; transform:none; transition-delay:0.2s; }
  .stagger.visible > *:nth-child(4) { opacity:1; transform:none; transition-delay:0.3s; }

  .h-line {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(159,0,74,0.4), transparent);
    margin: 0 48px;
  }

  @media (max-width: 768px) {
    nav { padding: 20px 24px; }
    .nav-links { display: none; }
    .hero, section { padding: 100px 24px 80px; }
    .services-grid { grid-template-columns: 1fr; }
    .philosophy { grid-template-columns: 1fr; }
    .philosophy-visual { display: none; }
    .process-steps { grid-template-columns: 1fr 1fr; }
    .footer-top { flex-direction: column; gap: 40px; }
    .footer-links { gap: 40px; flex-wrap: wrap; }
    .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
    .h-line { margin: 0 24px; }
  }
  .marquee-item, .marquee-item span { color: #fff !important; }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>
<div class="progress-bar" id="progressBar"></div>

<nav id="navbar">
  <div class="nav-logo">MALVEC</div>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#contact" class="nav-cta">Let's Work</a></li>
  </ul>
</nav>

<section class="hero" id="home">
  <div class="hero-bg"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <div class="hero-tag">Digital Agency · Argentina</div>
  <h1 class="hero-title">We build<span class="line-grad">digital presence</span>that converts.</h1>
  <p class="hero-sub">
    Design, development and strategy for brands that want to stand out in a saturated world. From Buenos Aires to the world.
  </p>
  <div class="hero-actions">
    <a href="#services" class="btn-primary">Our Services</a>
    <a href="#contact" class="btn-ghost">Let's Talk &rarr;</a>
  </div>

  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<div class="marquee-section">
  <div class="marquee-track">
    <div class="marquee-item"><span>Web Development</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Branding</span><span class="dot"></span></div>
    <div class="marquee-item"><span>SEO / SEM</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Paid Ads</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Social Content</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Rebranding</span><span class="dot"></span></div>
    <div class="marquee-item"><span>UI/UX</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Digital Strategy</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Web Development</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Branding</span><span class="dot"></span></div>
    <div class="marquee-item"><span>SEO / SEM</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Paid Ads</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Social Content</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Rebranding</span><span class="dot"></span></div>
    <div class="marquee-item"><span>UI/UX</span><span class="dot"></span></div>
    <div class="marquee-item"><span>Digital Strategy</span><span class="dot"></span></div>
  </div>
</div>

<section class="services" id="services">
  <div class="services-header reveal">
    <div class="section-label">Services</div>
    <h2 class="section-title">Everything your brand needs</h2>
    <p>End-to-end solutions to build, grow and dominate your digital space.</p>
  </div>
  <div class="services-grid stagger">
    <div class="service-card" data-card>
      <div class="glass-highlight"></div>
